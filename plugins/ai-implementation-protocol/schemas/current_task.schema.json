{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIP Current Task",
  "type": "object",
  "required": [
    "feature_id",
    "status",
    "current_phase",
    "current_task",
    "next_action",
    "last_updated",
    "owner",
    "blocking",
    "must_read"
  ],
  "properties": {
    "feature_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["planned", "in_progress", "blocked", "done"]
    },
    "current_phase": { "type": "string", "minLength": 1 },
    "current_task": { "type": "string", "minLength": 1 },
    "next_action": { "type": "string", "minLength": 1 },
    "last_updated": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "blocking": {
      "type": "array",
      "items": { "type": "string" }
    },
    "must_read": {
      "type": "array",
      "items": { "type": "string" }
    },
    "kind": {
      "type": "string",
      "enum": ["feature", "bug"],
      "default": "feature",
      "description": "Work-unit type. 'feature' for normal feature development; 'bug' for defect investigation and fix."
    },
    "resolution": {
      "type": "string",
      "enum": ["fixed", "wont_fix", "by_design"],
      "description": "Bug close reason. Only present when a bug work-unit is done. Absent/null until closed."
    }
  }
}
